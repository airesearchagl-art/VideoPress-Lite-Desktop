{
  "name": "videopress-lite-desktop",
  "version": "1.2.0",
  "description": "VideoPress Lite Desktop - local video compression with native FFmpeg",
  "author": "AI Research AGL",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check renderer.js",
    "build": "npm run dist",
    "dist": "electron-builder --win nsis && node scripts/fix-latest-yml.js"
  },
  "build": {
    "appId": "jp.airesearchagl.videopress-lite-desktop",
    "productName": "VideoPress Lite Desktop",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "airesearchagl-art",
        "repo": "VideoPress-Lite-Desktop"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg/win",
        "to": "ffmpeg/win",
        "filter": [
          "ffmpeg.exe",
          "ffprobe.exe"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "VideoPress Lite Desktop Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VideoPress Lite Desktop"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  }
}
